{
  "name": "crxray",
  "version": "0.2.12",
  "description": "Download Chrome and Edge extension source code in one command — audit, deobfuscate, beautify, and diff. Paste a store link, get readable source on disk.",
  "type": "module",
  "bin": {
    "crxray": "bin/crxray.js"
  },
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "skill"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test \"test/*.test.js\""
  },
  "keywords": [
    "chrome-extension",
    "chrome-extension-source",
    "download-extension",
    "crx",
    "chrome-web-store",
    "edge-addons",
    "download",
    "source-code",
    "unpack",
    "security",
    "audit",
    "deobfuscate",
    "beautify",
    "diff",
    "ai-agents",
    "cli"
  ],
  "author": "Collin Boler",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/collinboler/crxray.git"
  },
  "homepage": "https://github.com/collinboler/crxray#readme",
  "bugs": {
    "url": "https://github.com/collinboler/crxray/issues"
  },
  "dependencies": {
    "crxray": "^0.2.0",
    "js-beautify": "^1.15.4",
    "webcrack": "^2.15.1"
  }
}
